{
    "type": "project",
    "require": {
        "php": ">=8.5",
        "symfony/framework-bundle": "^8.0",
        "symfony/yaml": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/runtime": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpunit/phpunit": "^13.0",
        "symfony/test-pack": "^1.2"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    }
}
